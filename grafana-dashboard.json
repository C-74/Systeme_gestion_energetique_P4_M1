{
  "title": "SRE Golden Signals - FastAPI",
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Trafic (Interactions / sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(streamlit_interactions_total[5m]))", "legendFormat": "Interactions utilisateurs" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Taux d'Erreurs (Crash script)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(streamlit_errors_total[5m]))", "legendFormat": "Erreurs script" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latence p95 (secondes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(streamlit_run_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Temps de chargement p95" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Saturation CPU & RAM (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "process_cpu_usage_percent", "legendFormat": "CPU %" },
        { "expr": "process_memory_usage_percent", "legendFormat": "RAM %" }
      ],
      "fieldConfig": { "defaults": { "max": 100, "min": 0 } }
    }
  ]
}